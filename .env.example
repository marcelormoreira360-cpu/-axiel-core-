# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Modelo por finalidade (ver lib/ai-models.ts):
#  - OPENAI_MODEL_CHAT: conversa de alto volume (bots WhatsApp/IG/FB/voz) + analytics leve. Default gpt-4o-mini (barato).
#  - OPENAI_MODEL_REPORT: trabalho clínico/estruturado (escriba, exames, insights, health-agent). Default gpt-4.1-mini.
# OPENAI_MODEL segue valendo como compat p/ o grupo REPORT (se OPENAI_MODEL_REPORT não vier).
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MODEL_CHAT=gpt-4o-mini
# OPENAI_MODEL_REPORT=gpt-4.1-mini

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=

# ── Communications ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=AXIEL Core <onboarding@resend.dev>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
NEXT_PUBLIC_DEFAULT_WHATSAPP_NUMBER=

# ── Meta (Messenger / Instagram / WhatsApp) ───────────────────────────────────
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID_1=
META_PAGE_ACCESS_TOKEN_2=
META_PAGE_ID_2=
# WhatsApp Business API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
# Facebook Pages (fallback para páginas não mapeadas)
META_FACEBOOK_PAGE_TOKEN=
# Instagram Direct
META_INSTAGRAM_TOKEN=
# Configurações do bot de agendamento via Meta
META_BOT_BOOKING_URL=
META_BOT_CLINIC_METHOD=
META_BOT_HUMAN_NAME=
META_BOT_PRACTITIONER_NAME=

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Zoom ─────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ── Daily.co (Teleconsulta) ───────────────────────────────────────────────────
DAILY_API_KEY=

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# URL mailto: ou https: do administrador
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Cron Jobs (OBRIGATÓRIO em produção — protege rotas /api/cron/*) ───────────
# Gere com: openssl rand -hex 32
CRON_SECRET=

# ── NFSe ─────────────────────────────────────────────────────────────────────
NFSE_API_KEY=
NFSE_COMPANY_ID=

# ── Sentry (opcional) ────────────────────────────────────────────────────────
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# ── PostHog (opcional — analytics de produto) ────────────────────────────────
# Sem a key, o analytics fica completamente desligado (nenhum script carregado).
NEXT_PUBLIC_POSTHOG_KEY=
# Host da instância (padrão: https://us.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=
